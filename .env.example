# Copy to .env.local and fill in before deploying.

# SIMPLEST lead delivery (free, no limits): pushes each lead to your team's
# phones via a Telegram bot. Setup (one time, ~2 min):
#   1. In Telegram, message @BotFather → /newbot → copy the bot token here.
#   2. Add the bot to a group (or DM it), send any message, then open
#      https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat":{"id":...}.
# Both must be set for Telegram delivery; it takes priority over LEAD_WEBHOOK_URL.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional advanced path: n8n / GoHighLevel (or any) inbound webhook URL that
# receives the raw lead JSON. Only used if Telegram vars above are empty.
LEAD_WEBHOOK_URL=

# Meta Pixel ID (Events Manager > Data Sources).
NEXT_PUBLIC_META_PIXEL_ID=

# GA4 Measurement ID, format G-XXXXXXXXXX.
NEXT_PUBLIC_GA4_ID=
